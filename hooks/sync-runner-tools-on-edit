#!/usr/bin/env bash
# PostToolUse hook: re-run sync-runner-tools when an e2e-*-runner.md agent file
# or the codegen script itself is edited. Background, never blocks the session.
set -eu

payload="$(cat)"

# Fast no-op: skip the python JSON parse if the payload can't possibly match.
# Catches 99% of edits in unrelated projects in <1ms instead of ~50-100ms.
case "$payload" in
  *e2e-*-runner.md*|*sync-runner-tools.mjs*) ;;
  *) exit 0 ;;
esac

file_path="$(printf '%s' "$payload" | /usr/bin/python3 -c 'import json,sys; d=json.load(sys.stdin); print((d.get("tool_input") or {}).get("file_path",""))' 2>/dev/null || true)"

case "$file_path" in
  "$HOME/.claude/agents/e2e-"*-runner.md|"$HOME/.claude/bin/sync-runner-tools.mjs")
    nohup /usr/bin/env node "$HOME/.claude/bin/sync-runner-tools.mjs" \
      >>"$HOME/.claude/logs/sync-runner-tools.log" 2>&1 &
    disown 2>/dev/null || true
    ;;
esac

exit 0
