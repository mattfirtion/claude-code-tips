#!/usr/bin/env bash
# PostToolUse hook: re-run sync-copilot when ~/.claude/commands/*.md changes.
# (Agent-file edits intentionally excluded — sync-copilot mirrors only commands/.)
# Reads JSON payload on stdin, fires script in background, never blocks the session.
set -eu

payload="$(cat)"

# Fast no-op: skip the python JSON parse if the payload can't possibly match.
case "$payload" in
  *.claude/commands/*.md*) ;;
  *) exit 0 ;;
esac

file_path="$(printf '%s' "$payload" | /usr/bin/python3 -c 'import json,sys; d=json.load(sys.stdin); print((d.get("tool_input") or {}).get("file_path",""))' 2>/dev/null || true)"

case "$file_path" in
  "$HOME/.claude/commands/"*.md)
    nohup /usr/bin/env node "$HOME/.claude/bin/sync-copilot.mjs" >/dev/null 2>&1 &
    disown 2>/dev/null || true
    ;;
esac

exit 0
