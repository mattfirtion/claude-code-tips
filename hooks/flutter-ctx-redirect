#!/bin/bash
# PreToolUse Bash warning: nudge `flutter test` / `flutter analyze` through
# ctx_batch_execute so the thousands of lines of output don't flood context.
# This is a warning (exit 0 with stderr note), NOT a block — single-file test
# runs with -t flag are fine to keep raw. Big suites get redirected.
set -euo pipefail

INPUT=$(cat)
TOOL=$(echo "$INPUT" | jq -r '.tool_name // empty')
[ "$TOOL" = "Bash" ] || exit 0

CMD=$(echo "$INPUT" | jq -r '.tool_input.command // ""')

# Only nudge for bare `flutter test` / `flutter analyze` with no scoping args
# and no output redirection. Allow targeted subsets through quietly.
if echo "$CMD" | grep -qE '(^|[^a-zA-Z])flutter[[:space:]]+(test|analyze)([[:space:]]|$)'; then
  if ! echo "$CMD" | grep -qE '(\.dart|>|--plain-name|--name|--coverage|--reporter)'; then
    echo "NOTE flutter $(echo "$CMD" | grep -oE 'flutter[[:space:]]+(test|analyze)' | awk '{print $2}') full-suite output is large. Consider mcp__plugin_context-mode_context-mode__ctx_batch_execute to keep raw output in the sandbox, or scope with a path/--plain-name. Proceeding anyway." >&2
  fi
fi
exit 0
